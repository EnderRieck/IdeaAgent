{
  "name": "idea-agent",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build && node dist/idea-agent/cli.js",
    "start:interactive": "npm run build && node dist/idea-agent/cli.js --interactive",
    "demo:core": "npm run build && node dist/idea-agent/demo/run-core-demo.js"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "fast-xml-parser": "^4.5.0",
    "ink": "^6.8.0",
    "jsdom": "^28.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.4",
    "turndown": "^7.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.13.1",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.7.3"
  }
}
